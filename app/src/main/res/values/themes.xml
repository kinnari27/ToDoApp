<resources>

    <style name="Theme.TodoApp" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Primary -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>

        <!-- Background & Surface -->
        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>

    </style>

    <!-- Toolbar/AppBar Overlay -->
    <style name="Theme.TodoApp.AppBarOverlay" parent="ThemeOverlay.Material3.ActionBar">
        <item name="android:textColorPrimary">@color/text_primary</item>
    </style>

    <!-- Popup Overlay -->
    <style name="Theme.TodoApp.PopupOverlay" parent="ThemeOverlay.Material3" />

</resources>