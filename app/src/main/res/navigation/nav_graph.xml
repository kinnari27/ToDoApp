<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.mytasklistapp.ui.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_taskList"
            app:destination="@id/taskListFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/taskListFragment"
        android:name="com.mytasklistapp.ui.TaskListFragment"
        android:label="My Tasks"
        tools:layout="@layout/fragment_task_list">
        <action
            android:id="@+id/action_taskList_to_addEditTask"
            app:destination="@id/addEditTaskFragment" />
        <action
            android:id="@+id/action_taskList_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/taskListFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/addEditTaskFragment"
        android:name="com.mytasklistapp.ui.AddEditTaskFragment"
        android:label="Add/Edit Task"
        tools:layout="@layout/fragment_add_edit_task" />

</navigation>
